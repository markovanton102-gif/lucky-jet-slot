---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';

const analogs = [
  { href: '/analogi/mines/', title: 'Mines', desc: 'Сапёр-формат, другая механика риска' },
  { href: '/analogi/spaceman/', title: 'Spaceman', desc: 'Космический crash от Pragmatic' },
  { href: '/analogi/aviator/', title: 'Aviator', desc: 'Классика жанра crash' },
  { href: '/analogi/plinko/', title: 'Plinko', desc: 'Шарик и множители' },
  { href: '/analogi/pilot/', title: 'Pilot', desc: 'Crash «пилот»' },
  { href: '/analogi/chicken-rush/', title: 'Chicken Rush', desc: 'Instant-игра' },
];
---

<BaseLayout
  title="Аналоги Lucky Jet"
  description="Игры похожие на Lucky Jet: Spaceman, Plinko, Pilot, Aviator и другие instant-слоты."
>
  <PageHero
    title="Аналоги игры Lucky Jet"
    lead="Если хочешь сменить формат — instant и crash-игры с похожей механикой риска и множителей."
  />
  <article class="content">
    <div class="container">
      <div class="card-grid">
        {analogs.map((a) => (
          <div class="card">
            <a href={a.href}>{a.title}</a>
            <p>{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </article>
</BaseLayout>
