---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import PlayButton from '../components/PlayButton.astro';
import { whereToPlay } from '../config';
---

<BaseLayout
  title="Где играть в Lucky Jet онлайн"
  description="Где играть в лаки джет онлайн: на что смотреть при выборе площадки, лицензия и выплаты."
>
  <PageHero
    title="Где играть в Lucky Jet"
    lead="Ищи площадки с instant-играми в каталоге, быстрым выводом и поддержкой твоего способа оплаты."
  />
  <article class="content">
    <div class="container">
      <h2>Площадки с Lucky Jet</h2>
      <div class="card-grid">
        {
          whereToPlay.map((item) => (
            <div class="card">
              <a href={item.url} rel="nofollow sponsored noopener" target="_blank">
                {item.name}
              </a>
            </div>
          ))
        }
      </div>

      <h2>Критерии выбора</h2>
      <ul>
        <li>Игра Lucky Jet есть в лобби (Pragmatic Play и др.)</li>
        <li>Поддержка твоей валюты и гео</li>
        <li>Удобное пополнение и вывод</li>
        <li>Мобильная версия без лагов</li>
      </ul>
      <p><PlayButton /></p>
    </div>
  </article>
</BaseLayout>
